{
    "name": "zsoltdunai/bookshop-php",
    "description": "Demo PHP bookshop application",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:sql": "phpunit --testsuite sql",
        "test:api": "phpunit --testsuite api",
        "test:integration": "phpunit --testsuite integration"
    }
}
